              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 0
            m_CallState: 2
    - text: Wow.. Ik kan niet geloven dat jij niet van kaas houd...
      options:
      - text: Sorry...
        linksToNumber: -1
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
  - name: Step_0
