--- !u!114 &6582609237864047217
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 6795397611812116778}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a75fee6ab0e27b345a75b26c604719be, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogueSequences:
  - state: 0
    stepNumber: 0
    sentences:
    - character: {fileID: 11400000, guid: a235e9f65a45f804783a1b72764842db, type: 2}
      text: '"Well hello there, little pup. You had quite the fall there. Are you
        alright?"'
      options:
      - text: Yes
        linksToNumber: 1
      - text: No
        linksToNumber: 3
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: e57b034b1b8cc5543a17eadafa0c7dcf, type: 2}
      text: '" I think so... Though I did fall from quite high."'
      options:
      - text: '>'
        linksToNumber: 2
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: a235e9f65a45f804783a1b72764842db, type: 2}
      text: '"But not a bruise or scratch on you, hohoh! You are stronger than you
        think."'
      options:
      - text: '>'
        linksToNumber: 5
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: e57b034b1b8cc5543a17eadafa0c7dcf, type: 2}
      text: '"No! D-did you see from how high I fell?! That must be like 100 hamsters
        t-tall!"'
      options:
      - text: '>'
        linksToNumber: 4
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: a235e9f65a45f804783a1b72764842db, type: 2}
      text: '"Alright calm down, little stuntman. You are going to be fine."'
      options:
      - text: '>'
        linksToNumber: 5
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: a235e9f65a45f804783a1b72764842db, type: 2}
      text: '"Can you tell me your name?"'
      options:
      - text: Name
        linksToNumber: 6
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: a235e9f65a45f804783a1b72764842db, type: 2}
      text: '"It''s Hammy, miss. Hammy the Hamster."'
      options:
      - text: '>'
        linksToNumber: 7
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: a235e9f65a45f804783a1b72764842db, type: 2}
      text: '"It''s nice to meet you, Hammy. I am Rita, and I welcome you to Rat
        City."'
      options:
      - text: Rat City?
        linksToNumber: 8
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: a235e9f65a45f804783a1b72764842db, type: 2}
      text: '"That''s right. We are a small community of rats that live down here.
        Many of us were born here, but some remember glimpses of The Bright and The
        Great Hand."'
      options:
      - text: Bright?
        linksToNumber: 9
      - text: Great Hand?
        linksToNumber: 10
      - text: '>'
        linksToNumber: 11
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: a235e9f65a45f804783a1b72764842db, type: 2}
      text: '"The Bright is what we call the world above our home. It''s where our
        resources flow from, and where The Great Hand resides."'
      options:
      - text: Great Hand?
        linksToNumber: 10
      - text: '>'
        linksToNumber: 11
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: a235e9f65a45f804783a1b72764842db, type: 2}
      text: '"The Great Hand is a powerful being which has watched over Rat City
        since its founding. It brought us to our new home through one of its vessels,
        and it brings us gifts in exchange for reverence."'
      options:
      - text: Bright?
        linksToNumber: 9
      - text: '>'
        linksToNumber: 11
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: a235e9f65a45f804783a1b72764842db, type: 2}
      text: '"Ofcourse, the people of Rat City also contribute a great deal to its
        success. especially with the Festival of Gratitude tonight."'
      options:
      - text: FESTIVAL?!
        linksToNumber: 12
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: e57b034b1b8cc5543a17eadafa0c7dcf, type: 2}
      text: '"A... FESTIVAL?! Oh my gosh, oh my gosh! Do you give presents to eachother,
        eat delicious food and like sing songs together?!"'
      options:
      - text: '>'
        linksToNumber: 13
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: a235e9f65a45f804783a1b72764842db, type: 2}
      text: '"Hohoh! All of that and more! The Festival of Gratitude is about thanking
        the people of the community."'
      options:
      - text: Join
        linksToNumber: 14
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: e57b034b1b8cc5543a17eadafa0c7dcf, type: 2}
      text: '"H: Oh wow... Can I join?"'
      options:
      - text: '>'
        linksToNumber: 15
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: a235e9f65a45f804783a1b72764842db, type: 2}
      text: '"R: Oh I''m sorry, little pup. The festival is meant for the people
        of the community. It wouldn''t be right if we let just anyone join the festivities.
        You haven''t even taken a step in the city itself!"'
      options:
      - text: Community
        linksToNumber: 16
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: e57b034b1b8cc5543a17eadafa0c7dcf, type: 2}
      text: '"H: Oh please please please please please! What if I become a community
        member, can I join then?!"'
      options:
      - text: '>'
        linksToNumber: 17
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: a235e9f65a45f804783a1b72764842db, type: 2}
      text: '"Well... I suppose if you can prove yourself to be a good pillar of
        the community, I suppose it would be only fair to allow you to join the festival."'
      options:
      - text: YAY!
        linksToNumber: 18
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: a235e9f65a45f804783a1b72764842db, type: 2}
      text: '"Hohoh! Such enthusiasm! Now let''s see what kind of tasks I can think
        of for you..."'
      options:
      - text: '>'
        linksToNumber: 19
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: a235e9f65a45f804783a1b72764842db, type: 2}
      text: '"Well the church is an important part of the community, so I''d probably
        say you should start there and speak to High Recycler Binjamin."'
      options:
      - text: '>'
        linksToNumber: 20
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: a235e9f65a45f804783a1b72764842db, type: 2}
      text: "\"Normally, there\u2019d be more to do, but this will be enough to show
        your dedication.\""
      options:
      - text: Okay!
        linksToNumber: 21
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: e57b034b1b8cc5543a17eadafa0c7dcf, type: 2}
      text: '"I will do my absolute best, miss. You won''t regret this!"'
      options:
      - text: '>'
        linksToNumber: 22
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 0}
            m_TargetAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_MethodName: SetActive
            m_Mode: 6
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 1
            m_CallState: 2
    - character: {fileID: 11400000, guid: a235e9f65a45f804783a1b72764842db, type: 2}
      text: '"Once you have completed Binjamin''s task, come speak to me at the town
        square."'
      options:
      - text: Bye
        linksToNumber: -1
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 6582609237864047217}
            m_TargetAssemblyTypeName: QuestNPC, Assembly-CSharp
            m_MethodName: OnStartQuest
            m_Mode: 1
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 1
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 0
            m_CallState: 2
  - state: 1
    stepNumber: 0
    sentences:
    - character: {fileID: 11400000, guid: a235e9f65a45f804783a1b72764842db, type: 2}
      text: '"Have you completed your task yet?"'
      options:
      - text: No
        linksToNumber: -1
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
  - state: 2
    stepNumber: 0
    sentences:
    - character: {fileID: 11400000, guid: a235e9f65a45f804783a1b72764842db, type: 2}
      text: '"I just had a rather flustered Binjamin inform me that you have done
        your task exceptionally well."'
      options:
      - text: Binjamin
        linksToNumber: 1
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: e57b034b1b8cc5543a17eadafa0c7dcf, type: 2}
      text: '"I didn''t really get what he was talking about, but he seemed really
        happy though!"'
      options:
      - text: '>'
        linksToNumber: 2
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: a235e9f65a45f804783a1b72764842db, type: 2}
      text: '"Hohoh! Right you are. but I''d say with that you have more than earned
        to join the festivities this evening."'
      options:
      - text: '>'
        linksToNumber: 3
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: a235e9f65a45f804783a1b72764842db, type: 2}
      text: '"R: The festivities will commence soon. Talk to me when you are ready,
        pup."'
      options:
      - text: Okay
        linksToNumber: -1
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 6582609237864047217}
            m_TargetAssemblyTypeName: QuestNPC, Assembly-CSharp
            m_MethodName: OnCompleteQuest
            m_Mode: 1
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 1
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 0
            m_CallState: 2
  - state: 3
    stepNumber: 0
    sentences:
    - character: {fileID: 11400000, guid: a235e9f65a45f804783a1b72764842db, type: 2}
      text: '"Are you ready?"'
      options:
      - text: Yes
        linksToNumber: 1
      - text: No
        linksToNumber: -1
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: a235e9f65a45f804783a1b72764842db, type: 2}
      text: '"Okay, let''s begin."'
      options:
      - text: '>'
        linksToNumber: -1
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
