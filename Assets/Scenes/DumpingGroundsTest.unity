--- !u!114 &365406697
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 365406695}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a75fee6ab0e27b345a75b26c604719be, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogueSequences:
  - state: 0
    stepNumber: 0
    sentences:
    - character: {fileID: 11400000, guid: d992168f14794d142a56ca46307aaf45, type: 2}
      text: '"Ah, a new face. Another soul brought to us by The Great Hand."'
      options:
      - text: Hi
        linksToNumber: 1
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: e57b034b1b8cc5543a17eadafa0c7dcf, type: 2}
      text: '"Yep! I''m Hammy. Nice to meet ya."'
      options:
      - text: '>'
        linksToNumber: 2
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: d992168f14794d142a56ca46307aaf45, type: 2}
      text: '"Likewise, friend, likewise."'
      options:
      - text: Help
        linksToNumber: 3
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: e57b034b1b8cc5543a17eadafa0c7dcf, type: 2}
      text: '"Miss Rita told me if I helped out, I would be allowed to join the festival."'
      options:
      - text: '>'
        linksToNumber: 4
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: d992168f14794d142a56ca46307aaf45, type: 2}
      text: '"Hmm... Acting out of self interest, but clearly stemming from a desire
        to spend time with others. Very well I have a task for you."'
      options:
      - text: '>'
        linksToNumber: 5
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: d992168f14794d142a56ca46307aaf45, type: 2}
      text: '"I have made this small effigy to offer to the Great Hand, but I''m
        afraid I''m a bit busy taking care of other matters."'
      options:
      - text: '>'
        linksToNumber: 6
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: d992168f14794d142a56ca46307aaf45, type: 2}
      text: '"B: Could you offer it in my stead at the shrine in the Dumping Grounds."'
      options:
      - text: Sure
        linksToNumber: 7
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: e57b034b1b8cc5543a17eadafa0c7dcf, type: 2}
      text: '"Sure! I''ll drop it off for you."'
      options:
      - text: '>'
        linksToNumber: 8
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: d992168f14794d142a56ca46307aaf45, type: 2}
      text: '"Don''t simply drop it off. Offer it. It''s a sign of our gratitude."'
      options:
      - text: Bye
        linksToNumber: -1
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 365406697}
            m_TargetAssemblyTypeName: QuestNPC, Assembly-CSharp
            m_MethodName: OnStartQuest
            m_Mode: 1
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 1
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 0
            m_CallState: 2
  - state: 1
    stepNumber: 0
    sentences:
    - character: {fileID: 11400000, guid: d992168f14794d142a56ca46307aaf45, type: 2}
      text: '"Bring the effigy to the Shrine in The Dumping Grounds."'
      options:
      - text: Bye
        linksToNumber: -1
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
  - state: 2
    stepNumber: 0
    sentences:
    - character: {fileID: 11400000, guid: d992168f14794d142a56ca46307aaf45, type: 2}
      text: '"You''re back. I assume everything went well?"'
      options:
      - text: Yes?
        linksToNumber: 1
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: e57b034b1b8cc5543a17eadafa0c7dcf, type: 2}
      text: '"Uhhh... I think? I placed your thingy down and then this big hand came
        and dropped a large bag down."'
      options:
      - text: '>'
        linksToNumber: 2
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: d992168f14794d142a56ca46307aaf45, type: 2}
      text: '"T-the Great Hand revealed itself to you after you made the offering?"'
      options:
      - text: Yeah?
        linksToNumber: 3
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: d992168f14794d142a56ca46307aaf45, type: 2}
      text: '"That''s incredible! This cannot be a coincedence... It must be a sign!"'
      options:
      - text: Yeah?
        linksToNumber: 4
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls: []
    - character: {fileID: 11400000, guid: d992168f14794d142a56ca46307aaf45, type: 2}
      text: '"Well, Child. You went above and beyond what I asked of you. I will
        vouch for you."'
      options:
      - text: Thanks!
        linksToNumber: -1
      textSpeed: 20
      OnDialogueEvent:
        m_PersistentCalls:
          m_Calls:
          - m_Target: {fileID: 365406697}
            m_TargetAssemblyTypeName: QuestNPC, Assembly-CSharp
            m_MethodName: OnCompleteQuest
            m_Mode: 1
            m_Arguments:
              m_ObjectArgument: {fileID: 0}
              m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
              m_IntArgument: 0
              m_FloatArgument: 0
              m_StringArgument: 
              m_BoolArgument: 0
            m_CallState: 2
  questData:
    name: BQ
    state: 0
    step: 0
  OnQuestStateUpdated:
    m_PersistentCalls:
      m_Calls: []
