      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 332114384489331421, guid: 94b23dce734773a4f84232969a2be45a, type: 3}
      propertyPath: dialogueSequences.Array.data[0].sentences.Array.size
      value: 3
      objectReference: {fileID: 0}
    - target: {fileID: 332114384489331421, guid: 94b23dce734773a4f84232969a2be45a, type: 3}
      propertyPath: dialogueSequences.Array.data[2].sentences.Array.size
      value: 2
      objectReference: {fileID: 0}
    - target: {fileID: 332114384489331421, guid: 94b23dce734773a4f84232969a2be45a, type: 3}
      propertyPath: dialogueSequences.Array.data[4].sentences.Array.size
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 332114384489331421, guid: 94b23dce734773a4f84232969a2be45a, type: 3}
      propertyPath: dialogueSequences.Array.data[0].sentences.Array.data[0].text
      value: Och wat heb ik een honger...
      objectReference: {fileID: 0}
    - target: {fileID: 332114384489331421, guid: 94b23dce734773a4f84232969a2be45a, type: 3}
      propertyPath: dialogueSequences.Array.data[0].sentences.Array.data[1].text
      value: Oh dat zou fijn zijn! Ik heb eigenlijk wel trek in een stukje kaas!
      objectReference: {fileID: 0}
    - target: {fileID: 332114384489331421, guid: 94b23dce734773a4f84232969a2be45a, type: 3}
      propertyPath: dialogueSequences.Array.data[0].sentences.Array.data[2].text
      value: Als je vanaf hier naar rechts loopt moet er een kaaswinkel zijn.
      objectReference: {fileID: 0}
    - target: {fileID: 332114384489331421, guid: 94b23dce734773a4f84232969a2be45a, type: 3}
      propertyPath: dialogueSequences.Array.data[1].sentences.Array.data[0].text
      value: Heb je de kaas al gevonden?
      objectReference: {fileID: 0}
    - target: {fileID: 332114384489331421, guid: 94b23dce734773a4f84232969a2be45a, type: 3}
      propertyPath: dialogueSequences.Array.data[2].sentences.Array.data[0].text
      value: Kaas is lekker, maar heb je er ook nog een broodje bij?
      objectReference: {fileID: 0}
    - target: {fileID: 332114384489331421, guid: 94b23dce734773a4f84232969a2be45a, type: 3}
      propertyPath: dialogueSequences.Array.data[2].sentences.Array.data[1].text
      value: Jaja, ga nou maar, ik heb honger.
      objectReference: {fileID: 0}
    - target: {fileID: 332114384489331421, guid: 94b23dce734773a4f84232969a2be45a, type: 3}
      propertyPath: dialogueSequences.Array.data[3].sentences.Array.data[0].text
      value: Oh dankjewel, maar in de tussentijd heb ik al wat anders gegeten
      objectReference: {fileID: 0}
    - target: {fileID: 332114384489331421, guid: 94b23dce734773a4f84232969a2be45a, type: 3}
      propertyPath: dialogueSequences.Array.data[4].sentences.Array.data[0].text
      value: Heheheh, nu heb ik soep EN een broodje kaas!!
      objectReference: {fileID: 0}
    - target: {fileID: 332114384489331421, guid: 94b23dce734773a4f84232969a2be45a, type: 3}
      propertyPath: dialogueSequences.Array.data[2].sentences.Array.data[1].textSpeed
      value: 20
      objectReference: {fileID: 0}
    - target: {fileID: 332114384489331421, guid: 94b23dce734773a4f84232969a2be45a, type: 3}
      propertyPath: dialogueSequences.Array.data[4].sentences.Array.data[0].textSpeed
      value: 20
      objectReference: {fileID: 0}
    - target: {fileID: 332114384489331421, guid: 94b23dce734773a4f84232969a2be45a, type: 3}
      propertyPath: dialogueSequences.Array.data[0].sentences.Array.data[1].options.Array.size
      value: 2
      objectReference: {fileID: 0}
    - target: {fileID: 332114384489331421, guid: 94b23dce734773a4f84232969a2be45a, type: 3}
      propertyPath: dialogueSequences.Array.data[0].sentences.Array.data[2].options.Array.size
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 332114384489331421, guid: 94b23dce734773a4f84232969a2be45a, type: 3}
      propertyPath: dialogueSequences.Array.data[2].sentences.Array.data[0].options.Array.size
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 332114384489331421, guid: 94b23dce734773a4f84232969a2be45a, type: 3}
      propertyPath: dialogueSequences.Array.data[2].sentences.Array.data[1].options.Array.size
      value: 0
      objectReference: {fileID: 0}
    - target: {fileID: 332114384489331421, guid: 94b23dce734773a4f84232969a2be45a, type: 3}
      propertyPath: dialogueSequences.Array.data[3].sentences.Array.data[0].options.Array.size
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 332114384489331421, guid: 94b23dce734773a4f84232969a2be45a, type: 3}
      propertyPath: dialogueSequences.Array.data[0].sentences.Array.data[0].options.Array.data[0].text
      value: Kan ik u helpen?
      objectReference: {fileID: 0}
    - target: {fileID: 332114384489331421, guid: 94b23dce734773a4f84232969a2be45a, type: 3}
      propertyPath: dialogueSequences.Array.data[0].sentences.Array.data[0].options.Array.data[1].text
      value: Nu even niet
      objectReference: {fileID: 0}
    - target: {fileID: 332114384489331421, guid: 94b23dce734773a4f84232969a2be45a, type: 3}
      propertyPath: dialogueSequences.Array.data[0].sentences.Array.data[1].options.Array.data[0].text
      value: Komt goed!
      objectReference: {fileID: 0}
    - target: {fileID: 332114384489331421, guid: 94b23dce734773a4f84232969a2be45a, type: 3}
      propertyPath: dialogueSequences.Array.data[0].sentences.Array.data[1].options.Array.data[1].text
      value: Waar vind ik dat?
      objectReference: {fileID: 0}
    - target: {fileID: 332114384489331421, guid: 94b23dce734773a4f84232969a2be45a, type: 3}
      propertyPath: dialogueSequences.Array.data[0].sentences.Array.data[2].options.Array.data[0].text
      value: Bedankt!
