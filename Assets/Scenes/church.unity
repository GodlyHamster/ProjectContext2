  m_Script: {fileID: 11500000, guid: 39dbd10d7d2e2fb45a2879e4f7fa7296, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  sentences:
  - character: {fileID: 11400000, guid: f4d04707cca8321458bd9a812d8e423f, type: 2}
    text: '"They say the High Recycler once lived in the world above."'
    options:
    - text: '>'
      linksToNumber: 1
    textSpeed: 20
    OnDialogueEvent:
      m_PersistentCalls:
        m_Calls: []
  - character: {fileID: 11400000, guid: f4d04707cca8321458bd9a812d8e423f, type: 2}
    text: '"He often was held in the grasp of The Great Hand for many hours."'
    options:
    - text: '>'
      linksToNumber: 2
    textSpeed: 20
    OnDialogueEvent:
